# Copy to .env and adjust values.
# cp .env.example .env

# ——— Database ———
# Default: SQLite (no Docker). For PostgreSQL (e.g. docker compose up -d), use:
# DATABASE_URL="postgresql://numeris:numeris@127.0.0.1:5432/numeris"
DATABASE_URL=file:./dev.db

# ——— Auth ———
# Secret for signing JWT access tokens. Use a long random string in production.
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# ——— Server ———
PORT=3000

# Optional: development | production | test
NODE_ENV=development
